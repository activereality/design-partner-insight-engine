{
  "name": "design-partner-insight-engine",
  "version": "0.0.0",
  "private": true,
  "description": "Docs-first monorepo scaffold for SignalForge, the Design Partner Insight Engine.",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --filter @signalforge/web dev",
    "dev:api": "pnpm --filter @signalforge/api dev",
    "dev:web": "pnpm --filter @signalforge/web dev",
    "format": "pnpm -r --if-present format",
    "lint": "pnpm -r --if-present lint",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck"
  }
}
