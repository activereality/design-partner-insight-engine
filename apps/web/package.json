{
  "name": "@signalforge/web",
  "version": "0.0.0",
  "private": true,
  "description": "SignalForge React app shell.",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && vite build --configLoader runner",
    "dev": "vite --host 127.0.0.1 --configLoader runner",
    "lint": "tsc -p tsconfig.json --noEmit",
    "preview": "vite preview --host 127.0.0.1 --configLoader runner",
    "test": "node -e \"console.log('No web tests yet. Add tests with behavior slices.')\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "typescript": "^5.7.2"
  }
}
