# SignalForge API local configuration
PORT=3000
NODE_ENV=development

# Local-development-only MongoDB credentials from docker-compose.yml.
# Do not reuse these values for production or shared environments.
MONGODB_URI=mongodb://signalforge_local:signalforge_local_password@localhost:27017/signalforge?authSource=admin

# AI extraction provider. Mock is default and requires no API key.
AI_PROVIDER=mock

# Local/demo-only seed and reset tools. Keep disabled unless intentionally demoing locally.
DEMO_TOOLS_ENABLED=false

# Server-side only. Required only when AI_PROVIDER=openai.
OPENAI_API_KEY=replace-with-server-side-key
OPENAI_MODEL=replace-with-current-openai-model
