{
  "name": "@signalforge/api",
  "version": "0.0.0",
  "private": true,
  "description": "SignalForge NestJS API shell.",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "pnpm run build && node dist/main.js",
